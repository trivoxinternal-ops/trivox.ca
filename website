                <div class="stat-value" id="approvedUsers">0</div>
                <div class="stat-label">Approved Users</div>
            </div>
        </div>

        <div class="tabs">
            <button class="tab active" onclick="showTab('pending')">⏳ Pending Requests</button>
            <button class="tab" onclick="showTab('approved')">✅ Approved Users</button>
            <button class="tab" onclick="showTab('all')">📋 All Users</button>
        </div>

        <div id="requestsContainer"></div>
    </div>

    <!-- Firebase -->
    <script src="https://www.gstatic.com/firebasejs/9.22.0/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.22.0/firebase-database-compat.js"></script>

    <script>
        // Firebase Config
        const firebaseConfig = {
            apiKey: "AIzaSyB38xae3qLe1NM3v9F6WyIS9L1s4RujPzM",
            authDomain: "trivox-ai.firebaseapp.com",
            databaseURL: "https://trivox-ai-default-rtdb.firebaseio.com",
            projectId: "trivox-ai",
            storageBucket: "trivox-ai.firebasestorage.app",
            messagingSenderId: "131013416793",
            appId: "1:131013416793:web:63ee8877d568cb6312de48",
            measurementId: "G-NQ13PN2WBR"
        };

        firebase.initializeApp(firebaseConfig);
        const db = firebase.database();

        let currentTab = 'pending';
        let allUsers = {};

        // Load users
        async function loadUsers() {
            try {
                const snapshot = await db.ref('users').once('value');
                allUsers = snapshot.val() || {};
                
                updateStats();
                displayUsers(currentTab);
            } catch (error) {
                console.error('Error loading users:', error);
            }
        }

        // Update statistics
        function updateStats() {
            const users = Object.values(allUsers);
            document.getElementById('totalUsers').textContent = users.length;
            document.getElementById('pendingRequests').textContent = users.filter(u => u.status === 'pending').length;
            document.getElementById('approvedUsers').textContent = users.filter(u => u.status === 'approved').length;
        }

        // Display users based on tab
        function displayUsers(tab) {
            currentTab = tab;
            const container = document.getElementById('requestsContainer');
            const users = Object.entries(allUsers);
            
            // Update active tab
            document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
            event?.target.classList.add('active');
            
            // Filter users
            let filteredUsers = users;
            if (tab === 'pending') {
                filteredUsers = users.filter(([id, user]) => user.status === 'pending');
            } else if (tab === 'approved') {
                filteredUsers = users.filter(([id, user]) => user.status === 'approved');
            }
            
            if (filteredUsers.length === 0) {
                container.innerHTML = `
                    <div class="empty-state">
                        <h3>No ${tab === 'all' ? 'users' : tab + ' requests'} found</h3>
                        <p>${tab === 'pending' ? 'All caught up! No pending access requests.' : ''}</p>
                    </div>
                `;
                return;
            }
            
            container.innerHTML = filteredUsers.map(([userId, user]) => `
                <div class="request-card">
                    <div class="request-header">
                        <div class="user-info">
                            <h3>${user.name}</h3>
                            <p>📧 ${user.email}</p>
                            <p>🏢 ${user.company}</p>
                            <p>🕐 Requested: ${new Date(user.requestedAt).toLocaleString()}</p>
                        </div>
                        <span class="status-badge status-${user.status}">${user.status.toUpperCase()}</span>
                    </div>
                    
                    <div class="request-details">
                        <div class="detail-row">
                            <span class="detail-label">Requested Role:</span>
                            <span><strong>${user.role.toUpperCase()}</strong></span>
                        </div>
                        <div class="detail-row">
                            <span class="detail-label">Reason:</span>
                            <span>${user.reason}</span>
                        </div>
                        ${user.approvedBy ? `
                            <div class="detail-row">
                                <span class="detail-label">Approved By:</span>
                                <span>${user.approvedBy} on ${new Date(user.approvedAt).toLocaleString()}</span>
                            </div>
                        ` : ''}
                    </div>
                    
                    <div class="actions">
                        ${user.status === 'pending' ? `
                            <button class="btn btn-approve" onclick="approveUser('${userId}')">
                                ✅ Approve
                            </button>
                            <button class="btn btn-deny" onclick="denyUser('${userId}')">
                                ❌ Deny
                            </button>
                        ` : ''}
                        ${user.status !== 'pending' ? `
                            <button class="btn btn-delete" onclick="deleteUser('${userId}')">
                                🗑️ Delete User
                            </button>
                        ` : ''}
                    </div>
                </div>
            `).join('');
        }

        // Approve user
        async function approveUser(userId) {
            if (!confirm('Approve this user?')) return;
            
            try {
                await db.ref(`users/${userId}`).update({
                    status: 'approved',
                    approvedBy: 'admin@trivoxai.com', // Email to be replaced.
                    approvedAt: Date.now()
                });
                
                alert('✅ User approved! They can now login.');
                loadUsers();
            } catch (error) {
                alert('Error approving user: ' + error.message);
            }
        }

        // Deny user
        async function denyUser(userId) {
            const reason = prompt('Enter reason for denial (optional):');
            
            try {
                await db.ref(`users/${userId}`).update({
                    status: 'denied',
                    deniedBy: 'admin@trivoxai.com',
                    deniedAt: Date.now(),
                    denialReason: reason || 'No reason provided'
                });
                
                alert('❌ User denied.');
                loadUsers();
            } catch (error) {
                alert('Error denying user: ' + error.message);
            }
        }

        // Delete user
        async function deleteUser(userId) {
            if (!confirm('⚠️ Are you sure you want to delete this user? This cannot be undone.')) return;
            
            try {
                await db.ref(`users/${userId}`).remove();
                alert('🗑️ User deleted.');
                loadUsers();
            } catch (error) {
                alert('Error deleting user: ' + error.message);
            }
        }

        // Show tab
        function showTab(tab) {
            displayUsers(tab);
        }

        // Load on page load
        loadUsers();

        //To be Reloaded every 30 seconds
        setInterval(loadUsers, 30000);
    </script>
</body>
