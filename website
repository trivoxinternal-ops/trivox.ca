        .cs-featured-video {
            position: relative;
            width: 100%;
            border-radius: 16px;
            overflow: hidden;
            border: 2px solid rgba(46, 97, 254, 0.35);
            box-shadow: 0 20px 50px rgba(0,0,0,0.5), 0 0 40px rgba(0,240,255,0.12);
