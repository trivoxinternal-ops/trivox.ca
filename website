            position: absolute;
            top: 20px;
            right: 20px;
            background: rgba(0, 240, 255, 0.2);
            backdrop-filter: blur(10px);
            border: 1px solid var(--cyan);
            padding: 8px 16px;
            border-radius: 30px;
            color: var(--cyan);
            font-size: 0.85rem;
            font-weight: 600;
            z-index: 2;
        }

        /* Hero Image Section */
        .hero-image-wrapper {
            max-width: 500px;
            margin: 3rem auto 0;
        }

        /* Service Card with Image */
        .service-card.with-image {
            padding: 0;
            overflow: hidden;
        }

        .service-card.with-image .service-image {
            width: 100%;
            height: 200px;
            object-fit: cover;
            border-bottom: 2px solid rgba(46, 97, 254, 0.3);
        }

        .service-card.with-image .service-content {
            padding: 2rem;
        }

        /* Image Grid */
        .image-grid {
            position: relative;
            height: 900px;
            margin: 3rem auto;
            max-width: 1200px;
            perspective: 1000px;
        }

        .image-grid-item {
            position: absolute;
            width: 240px;
            height: 240px;
            border-radius: 20px;
            overflow: hidden;
            border: 1px solid rgba(46, 97, 254, 0.3);
            box-shadow: 
                0 20px 60px rgba(0, 0, 0, 0.5),
                0 0 40px rgba(46, 97, 254, 0.3),
                inset 0 0 0 1px rgba(255, 255, 255, 0.1);
            background: linear-gradient(135deg, rgba(46, 97, 254, 0.1), rgba(0, 240, 255, 0.05));
            backdrop-filter: blur(10px);
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

        .image-grid-item::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(45deg, transparent, rgba(255, 255, 255, 0.1), transparent);
            opacity: 0;
            transition: opacity 0.3s ease;
            z-index: 1;
        }

        .image-grid-item:hover::before {
            opacity: 1;
        }

        .image-grid-item::after {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(0, 240, 255, 0.2) 0%, transparent 70%);
            opacity: 0;
            transition: opacity 0.5s ease;
            pointer-events: none;
            z-index: 1;
        }

        .image-grid-item:hover::after {
            opacity: 1;
        }

        /* 4-column × 2-row even grid — no overlaps
           Container: 1200px wide × 900px tall  |  Item: 240px × 240px
           Col left edges: 0, 320, 640, 960  (240 item + 80 gap)
           Row top edges:  130, 530           (240 item + 160 gap, centred vertically) */
        .image-grid-item:nth-child(1) {
            top: 130px; left: 0;
            animation: float1 20s ease-in-out infinite;
            animation-delay: 0s;
        }
        .image-grid-item:nth-child(2) {
            top: 130px; left: 320px;
            animation: float2 18s ease-in-out infinite;
            animation-delay: -3s;
        }
        .image-grid-item:nth-child(3) {
            top: 130px; left: 640px;
            animation: float3 22s ease-in-out infinite;
            animation-delay: -6s;
        }
        .image-grid-item:nth-child(4) {
            top: 130px; left: 960px;
            animation: float4 19s ease-in-out infinite;
            animation-delay: -9s;
        }
        .image-grid-item:nth-child(5) {
            top: 530px; left: 0;
            animation: float5 21s ease-in-out infinite;
            animation-delay: -12s;
        }
        .image-grid-item:nth-child(6) {
            top: 530px; left: 320px;
            animation: float2 23s ease-in-out infinite;
            animation-delay: -4s;
        }
        .image-grid-item:nth-child(7) {
            top: 530px; left: 640px;
            animation: float3 20s ease-in-out infinite;
            animation-delay: -8s;
        }
        .image-grid-item:nth-child(8) {
            top: 530px; left: 960px;
            animation: float1 25s ease-in-out infinite;
            animation-delay: -15s;
        }

        /* Floating animations with 3D transforms */
        @keyframes float1 {
            0%, 100% {
                transform: translate(0, 0) rotateY(0deg) rotateX(0deg);
            }
            25% {
                transform: translate(30px, -40px) rotateY(5deg) rotateX(-3deg);
            }
            50% {
                transform: translate(-20px, -60px) rotateY(-5deg) rotateX(3deg);
            }
            75% {
                transform: translate(40px, -30px) rotateY(3deg) rotateX(-2deg);
            }
        }

        @keyframes float2 {
            0%, 100% {
                transform: translate(0, 0) rotateY(0deg) rotateX(0deg);
            }
            25% {
                transform: translate(-35px, 45px) rotateY(-6deg) rotateX(4deg);
            }
            50% {
                transform: translate(25px, 65px) rotateY(4deg) rotateX(-3deg);
            }
            75% {
                transform: translate(-30px, 35px) rotateY(-3deg) rotateX(2deg);
            }
        }

        @keyframes float3 {
            0%, 100% {
                transform: translate(0, 0) rotateY(0deg) rotateX(0deg);
            }
            25% {
                transform: translate(45px, 35px) rotateY(7deg) rotateX(-4deg);
            }
            50% {
                transform: translate(-30px, 55px) rotateY(-4deg) rotateX(5deg);
            }
            75% {
                transform: translate(35px, 25px) rotateY(4deg) rotateX(-3deg);
            }
        }

        @keyframes float4 {
            0%, 100% {
                transform: translate(0, 0) rotateY(0deg) rotateX(0deg);
            }
            25% {
                transform: translate(-40px, -35px) rotateY(-5deg) rotateX(3deg);
            }
            50% {
                transform: translate(30px, -50px) rotateY(6deg) rotateX(-4deg);
            }
            75% {
                transform: translate(-25px, -25px) rotateY(-3deg) rotateX(2deg);
            }
        }

        @keyframes float5 {
            0%, 100% {
                transform: translate(0, 0) rotateY(0deg) rotateX(0deg);
            }
            25% {
                transform: translate(25px, -30px) rotateY(4deg) rotateX(-3deg);
            }
            50% {
                transform: translate(-35px, 40px) rotateY(-5deg) rotateX(4deg);
            }
            75% {
                transform: translate(30px, 20px) rotateY(3deg) rotateX(-2deg);
            }
        }

        .image-grid-item:hover {
            transform: scale(1.05) !important;
            z-index: 10;
            border-color: var(--cyan);
            box-shadow: 
                0 30px 80px rgba(0, 0, 0, 0.6),
                0 0 60px rgba(46, 97, 254, 0.5),
                inset 0 0 0 1px rgba(255, 255, 255, 0.2);
        }

        .image-grid-item img,
        .image-grid-item svg {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
            opacity: 0.9;
            transition: opacity 0.3s ease;
            position: relative;
            z-index: 0;
        }

        .image-grid-item:hover img,
        .image-grid-item:hover svg {
            opacity: 1;
        }

        .image-grid-caption {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            background: linear-gradient(to top, rgba(10,14,39,0.95), transparent);
            padding: 20px;
            color: white;
            font-weight: 600;
            transform: translateY(100%);
            transition: transform 0.3s ease;
            z-index: 2;
        }

        .image-grid-item:hover .image-grid-caption {
            transform: translateY(0);
        }

        /* ========== SECTIONS ========== */
        section {
            padding: 6rem 2rem;
            max-width: 1400px;
            margin: 0 auto;
        }

        .section-header {
            text-align: center;
            margin-bottom: 4rem;
        }

        .section-badge {
            display: inline-block;
            background: rgba(46, 97, 254, 0.1);
            border: 1px solid rgba(46, 97, 254, 0.3);
            color: var(--cyan);
            padding: 0.5rem 1rem;
            border-radius: 50px;
            font-size: 0.85rem;
            font-weight: 600;
            margin-bottom: 1rem;
        }

        .section-title {
            font-size: 2.5rem;
            font-weight: 800;
            margin-bottom: 1rem;
            background: linear-gradient(135deg, var(--text-light), var(--text-gray));
            -webkit-background-clip: text;
            background-clip: text;
        }

        .section-subtitle {
            font-size: 1.1rem;
            color: var(--text-gray);
            max-width: 700px;
            margin: 0 auto;
        }

        /* ========== HERO SECTION ========== */
        .hero {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 8rem 2rem 4rem;
            text-align: center;
        }

        .hero-badge {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            background: rgba(46, 97, 254, 0.1);
            border: 1px solid rgba(46, 97, 254, 0.3);
            padding: 0.5rem 1rem;
            border-radius: 50px;
            color: var(--cyan);
            font-size: 0.85rem;
            font-weight: 600;
            margin-bottom: 1.5rem;
        }

        .badge-dot {
            width: 8px;
            height: 8px;
            background: var(--cyan);
            border-radius: 50%;
            animation: pulse 2s infinite;
        }

        @keyframes pulse {
            0%, 100% { opacity: 1; transform: scale(1); }
            50% { opacity: 0.5; transform: scale(1.2); }
        }

        .hero-title {
            font-size: 3.5rem;
            font-weight: 800;
            line-height: 1.1;
            margin-bottom: 1.5rem;
            max-width: 900px;
        }

        .gradient-text {
            background: linear-gradient(135deg, var(--primary-blue), var(--cyan));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            animation: gradientShift 3s ease infinite;
        }

        @keyframes gradientShift {
            0%, 100% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
        }

        .hero-subtitle {
            font-size: 1.2rem;
            color: var(--text-gray);
            line-height: 1.8;
            margin-bottom: 2rem;
            max-width: 700px;
            margin-left: auto;
            margin-right: auto;
        }

        .hero-stats {
            display: flex;
            gap: 3rem;
            justify-content: center;
            margin-bottom: 2.5rem;
            padding: 1.5rem 0;
            border-top: 1px solid rgba(46, 97, 254, 0.2);
            border-bottom: 1px solid rgba(46, 97, 254, 0.2);
            flex-wrap: wrap;
        }

        .stat-item {
            text-align: center;
        }

        .stat-number {
            font-size: 2.5rem;
            font-weight: 800;
            color: var(--cyan);
            font-family: 'Space Mono', monospace;
        }

        .stat-label {
            font-size: 0.85rem;
            color: var(--text-gray);
            margin-top: 0.3rem;
        }

        .hero-cta {
            display: flex;
            gap: 1rem;
            justify-content: center;
            margin-bottom: 2rem;
            flex-wrap: wrap;
        }

        .cta-primary,
        .cta-secondary {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            padding: 1rem 2rem;
            border-radius: 10px;
            text-decoration: none;
            font-weight: 600;
            font-size: 1rem;
            transition: all 0.3s ease;
            cursor: none;
        }

        .cta-primary {
            background: linear-gradient(135deg, var(--primary-blue), var(--secondary-blue));
            color: white;
            box-shadow: 0 8px 25px rgba(46, 97, 254, 0.4);
        }

        .cta-primary:hover {
            transform: translateY(-3px);
            box-shadow: 0 12px 35px rgba(46, 97, 254, 0.6);
        }

        .cta-secondary {
            background: rgba(46, 97, 254, 0.1);
            border: 2px solid var(--primary-blue);
            color: var(--text-light);
        }

        .cta-secondary:hover {
            background: rgba(46, 97, 254, 0.2);
            border-color: var(--cyan);
