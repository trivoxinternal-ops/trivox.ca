            -webkit-text-fill-color: transparent;
            background-clip: text;
            line-height: 1.1;
            margin-bottom: 0.5rem;
        }

        .cs-stat-label {
            font-size: 0.85rem;
            color: var(--text-gray);
            font-weight: 500;
            line-height: 1.4;
        }

