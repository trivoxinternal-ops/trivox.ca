                    sentences[current].classList.add('rot-exit');
                    dots[current].classList.remove('active');
                    const prev = current;
                    setTimeout(() => sentences[prev].classList.remove('rot-exit'), 650);

                    current = (idx + sentences.length) % sentences.length;
                    sentences[current].classList.add('rot-active');
                    dots[current].classList.add('active');
                }

                function start() {
                    if (started) return;
                    started = true;
                    // show first
                    sentences[0].classList.add('rot-active');
                    timer = setInterval(() => showSlide(current + 1), 3800);
                }

                // kick off when section scrolls into view
                const observer = new IntersectionObserver(entries => {
                    if (entries[0].isIntersecting) { start(); observer.disconnect(); }
                }, { threshold: 0.3 });
                observer.observe(rotator);
            })();
            </script>

