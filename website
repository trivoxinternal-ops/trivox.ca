        .cs-hero h3 {
            font-size: 2rem;
            font-weight: 800;
            background: linear-gradient(135deg, #fff, var(--cyan));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 0.5rem;
        }

        .cs-hero .cs-subtitle {
            font-size: 1.15rem;
            color: var(--cyan);
            font-weight: 600;
            margin-bottom: 1rem;
        }

        .cs-hero p {
            color: var(--text-gray);
            line-height: 1.8;
