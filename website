            display: flex;
            align-items: center;
            gap: 1rem;
            margin-bottom: 1.5rem;
            padding-top: 1.5rem;
            border-top: 1px solid rgba(46, 97, 254, 0.2);
        }

        .author-avatar {
            width: 50px;
            height: 50px;
            background: linear-gradient(135deg, var(--primary-blue), var(--cyan));
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: 700;
        }

        .author-name {
            font-weight: 600;
            color: var(--text-light);
        }

        .author-role {
            font-size: 0.85rem;
            color: var(--text-gray);
        }

