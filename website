        .cs-media {
            background: rgba(15, 20, 41, 0.4);
            border: 1px solid rgba(46, 97, 254, 0.15);
            border-radius: 16px;
            padding: 2.5rem 3rem;
        }

        .cs-media h4 {
            font-size: 1.3rem;
            font-weight: 700;
            color: #fff;
            margin-bottom: 2rem;
        }

