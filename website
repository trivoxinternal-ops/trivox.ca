        .cs-bullets li {
            background: rgba(46, 97, 254, 0.12);
            border: 1px solid rgba(46, 97, 254, 0.3);
            border-radius: 8px;
            padding: 0.5rem 1rem;
            color: var(--text-gray);
            font-size: 0.95rem;
        }

        .cs-bullets li::before {
            content: '→ ';
            color: var(--cyan);
            font-weight: 700;
        }

        .cs-stats {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 1.5rem;
            margin-bottom: 2rem;
        }

        .cs-stat-card {
            background: rgba(15, 20, 41, 0.8);
            border: 1px solid rgba(46, 97, 254, 0.25);
