        .cs-tabs {
            display: flex;
            gap: 1rem;
            justify-content: center;
            margin-bottom: 3rem;
        }

        .cs-tab {
            padding: 0.75rem 2rem;
            border-radius: 50px;
            border: 2px solid rgba(46, 97, 254, 0.4);
            background: transparent;
            color: var(--text-gray);
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            font-family: inherit;
        }

        .cs-tab.active,
        .cs-tab:hover {
            background: linear-gradient(135deg, var(--primary-blue), var(--cyan));
            border-color: transparent;
            color: #fff;
        }

        .cs-panel {
            display: none;
        }

        .cs-panel.active {
            display: block;
        }

        .cs-hero {
            background: rgba(15, 20, 41, 0.6);
            border: 1px solid rgba(46, 97, 254, 0.2);
            border-radius: 16px;
            padding: 2.5rem 3rem;
            margin-bottom: 2rem;
