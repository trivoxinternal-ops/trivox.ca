            margin-left: 4px;
        }

        .cs-featured-video-overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(to top, rgba(10,14,39,0.7) 0%, transparent 50%);
            z-index: 2;
            pointer-events: none;
        }

        .cs-featured-video-label {
            position: absolute;
            bottom: 20px;
            left: 24px;
            z-index: 3;
            pointer-events: none;
        }

        .cs-featured-video-label span {
            display: block;
            font-size: 0.72rem;
            font-weight: 700;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: var(--cyan);
            margin-bottom: 4px;
        }

        .cs-featured-video-label p {
            font-size: 1.1rem;
            font-weight: 700;
            color: #fff;
            margin: 0;
        }

        /* --- Film Strip --- */
        .cs-strip-wrapper {
            position: relative;
            margin-bottom: 0.5rem;
        }

        .cs-strip-label-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 1rem;
        }

        .cs-strip-label-row .cs-section-label {
            margin: 0;
        }

        .cs-strip-hint {
            font-size: 0.78rem;
            color: var(--text-gray);
            display: flex;
            align-items: center;
            gap: 0.4rem;
        }

        .cs-film-strip {
            display: flex;
            gap: 1rem;
            overflow-x: auto;
            padding: 0.5rem 0 1.25rem;
            scroll-snap-type: x mandatory;
            -webkit-overflow-scrolling: touch;
            scrollbar-width: thin;
            scrollbar-color: rgba(46,97,254,0.4) transparent;
        }

        .cs-film-strip::-webkit-scrollbar {
            height: 5px;
        }
        .cs-film-strip::-webkit-scrollbar-track {
            background: rgba(46,97,254,0.05);
            border-radius: 10px;
        }
        .cs-film-strip::-webkit-scrollbar-thumb {
            background: linear-gradient(90deg, var(--primary-blue), var(--cyan));
            border-radius: 10px;
        }

        .cs-strip-card {
            flex: 0 0 260px;
            height: 190px;
            border-radius: 12px;
            overflow: hidden;
            border: 1.5px solid rgba(46, 97, 254, 0.25);
            background: rgba(15,20,41,0.8);
            scroll-snap-align: start;
            cursor: pointer;
            position: relative;
            transition: border-color 0.3s, box-shadow 0.3s, transform 0.3s;
            box-shadow: 0 8px 24px rgba(0,0,0,0.35);
        }

        .cs-strip-card:hover {
            border-color: var(--cyan);
            box-shadow: 0 12px 36px rgba(0,0,0,0.5), 0 0 24px rgba(0,240,255,0.2);
            transform: translateY(-6px) scale(1.02);
        }

        .cs-strip-card img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            object-position: top;
            display: block;
            transition: transform 0.4s ease;
        }

        .cs-strip-card:hover img {
            transform: scale(1.07);
        }

        .cs-strip-card-overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(to top, rgba(10,14,39,0.75) 0%, transparent 55%);
            opacity: 0;
            transition: opacity 0.3s;
            display: flex;
            align-items: flex-end;
            padding: 12px 14px;
            z-index: 2;
        }

        .cs-strip-card:hover .cs-strip-card-overlay {
            opacity: 1;
        }

        .cs-strip-card-overlay span {
            font-size: 0.75rem;
            font-weight: 600;
            color: var(--cyan);
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .cs-strip-zoom-icon {
            position: absolute;
            top: 10px;
            right: 10px;
            width: 32px;
            height: 32px;
            background: rgba(0,240,255,0.18);
            backdrop-filter: blur(8px);
            border: 1px solid rgba(0,240,255,0.4);
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            transition: opacity 0.3s;
            z-index: 3;
        }

        .cs-strip-card:hover .cs-strip-zoom-icon {
            opacity: 1;
        }

        .cs-strip-zoom-icon svg {
            width: 15px;
            height: 15px;
            stroke: var(--cyan);
            fill: none;
        }

        /* Strip scroll arrows */
        .cs-strip-arrow {
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            width: 38px;
            height: 38px;
            background: rgba(10,14,39,0.85);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(46,97,254,0.4);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            z-index: 10;
            transition: all 0.2s;
            color: var(--cyan);
            font-size: 1rem;
            user-select: none;
        }

        .cs-strip-arrow:hover {
            background: rgba(46,97,254,0.3);
            border-color: var(--cyan);
            box-shadow: 0 0 16px rgba(0,240,255,0.3);
        }

        .cs-strip-arrow.prev { left: -18px; }
        .cs-strip-arrow.next { right: -18px; }

        /* ========== LIGHTBOX ========== */
        .cs-lightbox {
            position: fixed;
            inset: 0;
            background: rgba(5, 8, 22, 0.93);
            z-index: 200000;
            display: flex;
            align-items: center;
            justify-content: center;
            backdrop-filter: blur(6px);
            opacity: 0;
            visibility: hidden;
            transition: opacity 0.3s ease, visibility 0.3s ease;
        }

        .cs-lightbox.active {
            opacity: 1;
            visibility: visible;
        }

        .cs-lightbox-inner {
            position: relative;
            width: 70vw;
            max-width: 860px;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .cs-lightbox-img-wrap {
            position: relative;
            width: 100%;
            border-radius: 14px;
            overflow: hidden;
            border: 1.5px solid rgba(0,240,255,0.25);
            box-shadow: 0 30px 80px rgba(0,0,0,0.8), 0 0 50px rgba(0,240,255,0.12);
            display: flex;
            align-items: center;
            justify-content: center;
            background: rgba(15,20,41,0.95);
        }

        .cs-lightbox-img-wrap img {
            width: 100%;
            max-height: 65vh;
            object-fit: contain;
            object-position: center;
            display: block;
            border-radius: 12px;
        }

        .cs-lightbox-caption {
            margin-top: 1rem;
            font-size: 0.85rem;
            color: var(--text-gray);
            text-align: center;
            letter-spacing: 0.5px;
        }

        .cs-lightbox-counter {
            font-size: 0.8rem;
            color: var(--cyan);
            margin-top: 0.3rem;
            font-family: 'Space Mono', monospace;
        }

        .cs-lightbox-close {
            position: absolute;
            top: -52px;
            right: 0;
            width: 42px;
            height: 42px;
            background: rgba(255,255,255,0.1);
            border: 1px solid rgba(255,255,255,0.2);
            border-radius: 50%;
            color: #fff;
            font-size: 1.3rem;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.2s;
            z-index: 5;
        }

        .cs-lightbox-close:hover {
            background: rgba(0,240,255,0.2);
            border-color: var(--cyan);
            color: var(--cyan);
        }

        .cs-lightbox-nav {
            position: fixed;
            top: 50%;
            transform: translateY(-50%);
            width: 50px;
            height: 50px;
            background: rgba(10,14,39,0.85);
            border: 1.5px solid rgba(46,97,254,0.5);
            border-radius: 50%;
            color: var(--cyan);
            font-size: 1.3rem;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.2s;
            z-index: 10;
        }

        .cs-lightbox-nav:hover {
            background: rgba(46,97,254,0.3);
            border-color: var(--cyan);
            box-shadow: 0 0 20px rgba(0,240,255,0.3);
        }

        .cs-lightbox-nav.prev { left: 20px; }
        .cs-lightbox-nav.next { right: 20px; }

        /* Thumbnail strip inside lightbox */
        .cs-lightbox-thumbs {
            display: flex;
            gap: 0.6rem;
            margin-top: 1rem;
            overflow-x: auto;
            max-width: 88vw;
            padding-bottom: 4px;
            scrollbar-width: none;
        }

        .cs-lightbox-thumbs::-webkit-scrollbar { display: none; }

        .cs-lightbox-thumb {
            flex: 0 0 64px;
            height: 46px;
            border-radius: 6px;
            overflow: hidden;
            border: 2px solid transparent;
            cursor: pointer;
            opacity: 0.5;
            transition: all 0.2s;
        }

        .cs-lightbox-thumb.active,
        .cs-lightbox-thumb:hover {
            border-color: var(--cyan);
            opacity: 1;
            box-shadow: 0 0 12px rgba(0,240,255,0.3);
        }

        .cs-lightbox-thumb img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            object-position: top;
        }

        /* old selectors kept for compatibility */
        .cs-screenshots-row { display: none; }
        .cs-screenshot { display: none; }
        .cs-screenshot-single { display: none; }

        /* small bouncing demo video thumbnail — kept for popup compat */
        .cs-video-wrap { display: none; }
        .cs-video-hint { display: none; }

        /* demo video popup */
        .cs-demo-overlay {
            display: none;
            position: fixed;
            top: 0; left: 0;
            width: 100%; height: 100%;
            background: rgba(0,0,0,0.82);
            z-index: 100000;
            align-items: center;
            justify-content: center;
            opacity: 0;
            transition: opacity 0.3s ease;
            backdrop-filter: blur(5px);
        }

        .cs-demo-overlay.active {
            display: flex;
            opacity: 1;
        }

        .cs-demo-container {
            position: relative;
            width: 40%;
            max-width: 480px;
            background: transparent;
            border: none;
            box-shadow: 0 20px 60px rgba(0,0,0,0.8);
            padding: 0;
            transform: scale(0.85);
            transition: transform 0.3s ease;
        }

        .cs-demo-overlay.active .cs-demo-container {
            transform: scale(1);
        }

        .cs-demo-close {
            position: absolute;
            top: -50px; right: 0;
            width: 42px; height: 42px;
            background: rgba(255,255,255,0.12);
            border: 1px solid rgba(255,255,255,0.25);
            border-radius: 50%;
            color: #fff;
            font-size: 1.4rem;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s ease;
            z-index: 10;
        }

        .cs-demo-close:hover {
            background: rgba(0,240,255,0.2);
            border-color: var(--cyan);
            color: var(--cyan);
        }

        .cs-demo-content {
            position: relative;
            width: 100%;
            padding-bottom: 56.25%;
            height: 0;
            overflow: hidden;
            background: #000;
            border-radius: 14px;
            border: 1.5px solid rgba(0,240,255,0.2);
            box-shadow: 0 0 50px rgba(0,240,255,0.1);
        }

        .cs-demo-content video {
            position: absolute;
            top: 0; left: 0;
            width: 100%; height: 100%;
            border-radius: 12px;
            pointer-events: auto;
            cursor: auto;
        }

        .cs-demo-overlay, .cs-demo-container, .cs-demo-close {
            cursor: auto;
        }
        .cs-demo-close { cursor: pointer; }

        /* Responsive film strip */
        @media (max-width: 768px) {
            .cs-strip-card { flex: 0 0 200px; height: 145px; }
            .cs-featured-video video { max-height: 280px; }
            .cs-strip-arrow { display: none; }
            .cs-media { padding: 1.5rem; }
        }

        .cs-divider {
            height: 1px;
            background: linear-gradient(90deg, transparent, rgba(46, 97, 254, 0.4), transparent);
            margin: 1rem 0 2.5rem;
        }

        .cs-section-label {
            font-size: 0.8rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 2px;
            color: var(--cyan);
            margin-bottom: 1rem;
        }

        /* ========== CONTACT FORM ========== */
        .contact-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 4rem;
            margin: 4rem 0;
        }

        .contact-form {
            background: rgba(15, 20, 41, 0.6);
            border: 1px solid rgba(46, 97, 254, 0.2);
            border-radius: 20px;
            padding: 3rem;
        }

        .form-group {
            margin-bottom: 1.5rem;
        }

        .form-group label {
            display: block;
            color: var(--text-light);
            margin-bottom: 0.5rem;
            font-weight: 600;
        }

        .form-group input,
        .form-group textarea,
        .form-group select {
            width: 100%;
            padding: 1rem;
            border-radius: 8px;
            border: 1px solid rgba(46, 97, 254, 0.3);
            background: rgba(10, 14, 39, 0.8);
            color: var(--text-light);
            font-size: 1rem;
            font-family: 'Sora', sans-serif;
            transition: all 0.3s ease;
        }

        .form-group input:focus,
        .form-group textarea:focus,
        .form-group select:focus {
            outline: none;
            border-color: var(--cyan);
            box-shadow: 0 0 0 3px rgba(0, 240, 255, 0.1);
        }

        .form-group textarea {
            min-height: 120px;
            resize: vertical;
        }

        .submit-btn {
            width: 100%;
            padding: 1.2rem;
            background: linear-gradient(135deg, var(--primary-blue), var(--secondary-blue));
            color: white;
            border: none;
            border-radius: 10px;
            font-weight: 700;
            font-size: 1.1rem;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .submit-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 30px rgba(46, 97, 254, 0.4);
        }

        /* ========== ROI CALCULATOR ========== */
        .roi-calculator {
            background: rgba(15, 20, 41, 0.6);
            border: 1px solid rgba(46, 97, 254, 0.2);
            border-radius: 20px;
            padding: 3rem;
            margin: 4rem 0;
        }

        .slider-group {
            margin: 2rem 0;
        }

        .slider-group label {
            display: flex;
            justify-content: space-between;
            color: var(--text-light);
            margin-bottom: 1rem;
            font-weight: 600;
        }

        .slider {
            width: 100%;
            height: 8px;
            border-radius: 5px;
            background: rgba(46, 97, 254, 0.2);
            outline: none;
            -webkit-appearance: none;
        }

        .slider::-webkit-slider-thumb {
            -webkit-appearance: none;
            appearance: none;
            width: 20px;
            height: 20px;
            border-radius: 50%;
            background: var(--cyan);
            cursor: pointer;
            box-shadow: 0 0 10px rgba(0, 240, 255, 0.5);
        }

        .slider::-moz-range-thumb {
            width: 20px;
            height: 20px;
            border-radius: 50%;
            background: var(--cyan);
            cursor: pointer;
            box-shadow: 0 0 10px rgba(0, 240, 255, 0.5);
            border: none;
        }

        .roi-results {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 2rem;
            margin-top: 3rem;
            padding: 2rem;
            background: rgba(10, 14, 39, 0.5);
            border-radius: 16px;
        }

        .roi-metric {
            text-align: center;
        }

        .roi-value {
            font-size: 2.5rem;
            font-weight: 800;
            color: var(--cyan);
            font-family: 'Space Mono', monospace;
        }

        /* ========== FOOTER ========== */
        .footer {
            background: rgba(10, 14, 39, 0.95);
            border-top: 1px solid rgba(46, 97, 254, 0.2);
            padding: 4rem 2rem 2rem;
        }

        .footer-content {
            max-width: 1400px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 3rem;
            margin-bottom: 3rem;
        }

        .footer-section h4 {
            color: var(--text-light);
            font-size: 1.1rem;
            margin-bottom: 1rem;
            font-weight: 700;
        }

        .footer-section ul {
            list-style: none;
        }

        .footer-section ul li {
            margin-bottom: 0.7rem;
        }

        .footer-section ul li a {
            color: var(--text-gray);
            text-decoration: none;
            transition: all 0.3s ease;
            cursor: none;
        }

        .footer-section ul li a:hover {
            color: var(--cyan);
            padding-left: 5px;
        }

        .footer-bottom {
            max-width: 1400px;
            margin: 0 auto;
            padding-top: 2rem;
            border-top: 1px solid rgba(46, 97, 254, 0.2);
            text-align: center;
            color: var(--text-gray);
            font-size: 0.9rem;
        }

        /* ========== ANIMATIONS ========== */
        .fade-in {
            opacity: 0;
            transform: translateY(30px);
            transition: all 0.8s ease;
        }

        .fade-in.visible {
            opacity: 1;
            transform: translateY(0);
        }

        /* ========== RESPONSIVE ========== */
        @media (max-width: 1200px) {
            .contact-grid {
                grid-template-columns: 1fr;
            }
        }

        @media (max-width: 968px) {
            .image-grid {
                height: 500px;
            }

            .image-grid-item {
                width: 220px !important;
                height: 220px !important;
            }
        }

        @media (max-width: 768px) {
            .hero-title {
                font-size: 2.5rem;
            }
            
            .section-title {
                font-size: 2rem;
            }
            
            .hero-stats {
                flex-direction: column;
                gap: 1.5rem;
            }
            
            .hero-cta {
                flex-direction: column;
            }
            
            .services-grid,
            .testimonials-grid {
                grid-template-columns: 1fr;
            }

            .cs-stats {
                grid-template-columns: repeat(2, 1fr);
            }

            .cs-screenshots-row {
                grid-template-columns: 1fr;
            }

            .cs-hero,
            .cs-built,
            .cs-media {
                padding: 2rem 1.5rem;
            }

            .image-grid {
                height: 400px;
            }

            .image-grid-item {
                width: 180px !important;
                height: 180px !important;
            }

            .image-grid-item:nth-child(5) {
                display: none;
            }

            /* About section grid to single column on mobile */
            #about > div:first-of-type {
                grid-template-columns: 1fr !important;
            }
        }

        @media (max-width: 480px) {
            .hero-title {
                font-size: 2rem;
            }
            
            section {
                padding: 4rem 1rem;
            }

            .image-grid {
                height: 350px;
            }

            .image-grid-item {
                width: 150px !important;
                height: 150px !important;
            }

            .image-grid-item:nth-child(4),
            .image-grid-item:nth-child(5) {
                display: none;
            }
        }

        /* ========== UTILITY CLASSES ========== */
        .text-center {
            text-align: center;
        }

        .mb-2 {
            margin-bottom: 2rem;
        }

        .mt-4 {
            margin-top: 4rem;
        }

        .hidden {
            display: none;
        }

        /* ========== NOTIFICATION SYSTEM ========== */
        .notification-container {
            position: fixed;
            top: 100px;
            right: 30px;
            z-index: 10000;
            pointer-events: none;
        }

        .notification {
            background: rgba(15, 20, 41, 0.98);
            border: 2px solid var(--cyan);
            border-radius: 12px;
            padding: 1.5rem 2rem;
            margin-bottom: 1rem;
            min-width: 350px;
            max-width: 450px;
            pointer-events: all;
            transform: translateX(500px);
            opacity: 0;
            animation: slideIn 0.5s ease forwards;
            box-shadow: 0 10px 40px rgba(0, 240, 255, 0.3),
                        0 0 20px rgba(46, 97, 254, 0.2);
        }

        .notification.success {
            border-color: #00FF88;
            box-shadow: 0 10px 40px rgba(0, 255, 136, 0.3);
        }

        .notification.error {
            border-color: #FF4444;
            box-shadow: 0 10px 40px rgba(255, 68, 68, 0.3);
        }

        .notification.warning {
            border-color: #FFB800;
            box-shadow: 0 10px 40px rgba(255, 184, 0, 0.3);
        }

        .notification-header {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin-bottom: 0.5rem;
        }

        .notification-icon {
            font-size: 2rem;
            animation: pulse 2s infinite;
        }

        .notification-title {
            font-size: 1.2rem;
            font-weight: 700;
            color: var(--text-light);
        }

        .notification-message {
            color: var(--text-gray);
            font-size: 0.95rem;
            line-height: 1.5;
        }

        .notification-close {
            position: absolute;
            top: 1rem;
            right: 1rem;
            background: none;
            border: none;
            color: var(--text-gray);
            cursor: pointer;
            font-size: 1.5rem;
            opacity: 0.6;
            transition: opacity 0.3s;
        }

        .notification-close:hover {
            opacity: 1;
        }

        @keyframes slideIn {
            to {
                transform: translateX(0);
                opacity: 1;
            }
        }

        @keyframes pulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.1); }
        }

        /* ========== LOADING SPINNER ========== */
        .loading-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(10, 14, 39, 0.95);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            z-index: 99999;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.3s;
        }

        .loading-overlay.active {
            opacity: 1;
            pointer-events: all;
        }

        .spinner {
            width: 80px;
            height: 80px;
            border: 4px solid rgba(46, 97, 254, 0.2);
            border-top-color: var(--cyan);
            border-radius: 50%;
            animation: spin 1s linear infinite;
        }

        .loading-text {
            margin-top: 2rem;
            font-size: 1.2rem;
            color: var(--cyan);
            animation: pulse 2s infinite;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        /* ========== HONEYPOT (SPAM PROTECTION) ========== */
        .honeypot {
            position: absolute;
            left: -9999px;
            width: 1px;
            height: 1px;
            opacity: 0;
        }

        /* ========== FORM ENHANCEMENTS ========== */
        .char-counter {
            text-align: right;
            font-size: 0.85rem;
            color: var(--text-gray);
            margin-top: 0.3rem;
        }

        .form-group input:focus,
        .form-group textarea:focus {
            border-color: var(--cyan) !important;
            box-shadow: 0 0 15px rgba(0, 240, 255, 0.3);
        }

        .submit-btn {
            position: relative;
            overflow: hidden;
        }

        .submit-btn:disabled {
            opacity: 0.6;
            cursor: not-allowed;
        }

        .submit-btn::after {
            content: '';
            position: absolute;
            top: 50%;
            left: 50%;
            width: 0;
            height: 0;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.3);
            transform: translate(-50%, -50%);
            transition: width 0.6s, height 0.6s;
        }

        .submit-btn:active::after {
            width: 300px;
            height: 300px;
        }

        /* ========== THEME TOGGLE BUTTON ========== */
        .theme-toggle-wrapper {
            display: flex;
            align-items: center;
            margin-left: 1rem;
        }

        .theme-toggle {
            position: relative;
            width: 40px;
            height: 20px;
            background: rgba(46, 97, 254, 0.2);
            border-radius: 30px;
            cursor: pointer;
            transition: all 0.3s ease;
