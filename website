    <!-- Firebase -->
    <script src="https://www.gstatic.com/firebasejs/9.22.0/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.22.0/firebase-database-compat.js"></script>

    <script>
        // Background Animation
        const canvas = document.getElementById('bgCanvas');
        const ctx = canvas.getContext('2d');
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;

        const particles = [];
        for (let i = 0; i < 50; i++) {
            particles.push({
                x: Math.random() * canvas.width,
                y: Math.random() * canvas.height,
                vx: (Math.random() - 0.5) * 0.5,
                vy: (Math.random() - 0.5) * 0.5,
                size: Math.random() * 2 + 1
            });
        }

        function animate() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            
            particles.forEach(p => {
                p.x += p.vx;
                p.y += p.vy;
                if (p.x < 0 || p.x > canvas.width) p.vx *= -1;
                if (p.y < 0 || p.y > canvas.height) p.vy *= -1;
                
                ctx.beginPath();
                ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
                ctx.fillStyle = 'rgba(46, 97, 254, 0.5)';
                ctx.fill();
            });
            
            requestAnimationFrame(animate);
        }
        animate();

        // Firebase Config
        const firebaseConfig = {
            apiKey: "AIzaSyB38xae3qLe1NM3v9F6WyIS9L1s4RujPzM",
            authDomain: "trivox-ai.firebaseapp.com",
            databaseURL: "https://trivox-ai-default-rtdb.firebaseio.com",
            projectId: "trivox-ai",
            storageBucket: "trivox-ai.firebasestorage.app",
            messagingSenderId: "131013416793",
            appId: "1:131013416793:web:63ee8877d568cb6312de48",
            measurementId: "G-NQ13PN2WBR"
        };

        firebase.initializeApp(firebaseConfig);
        const db = firebase.database();

        // Login Form Handler
        document.getElementById('loginForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const email = document.getElementById('email').value.trim();
            const password = document.getElementById('password').value;
            const loginBtn = document.getElementById('loginBtn');
            const errorMsg = document.getElementById('errorMessage');
            const successMsg = document.getElementById('successMessage');
            
            // Clear messages
            errorMsg.style.display = 'none';
            successMsg.style.display = 'none';
            
            // Disable button
            loginBtn.disabled = true;
            loginBtn.textContent = '🔄 Checking credentials...';
            
            try {
                // Check if user exists and is approved
                const usersSnapshot = await db.ref('users').orderByChild('email').equalTo(email).once('value');
                
                if (!usersSnapshot.exists()) {
                    throw new Error('User not found. Please request access first.');
                }
                
                const userData = Object.values(usersSnapshot.val())[0];
                const userId = Object.keys(usersSnapshot.val())[0];
                
                // Check status
                if (userData.status === 'pending') {
                    throw new Error('Your access request is pending admin approval.');
                }
                
                if (userData.status === 'denied') {
                    throw new Error('Your access request was denied. Please contact admin.');
                }
                
                if (userData.status !== 'approved') {
                    throw new Error('Account not active. Please contact admin.');
                }
                
                // Verify password (simple hash check - in production use proper hashing)
                if (userData.password !== btoa(password)) {
                    throw new Error('Incorrect password.');
                }
                
                // Success! Store session
                sessionStorage.setItem('dashboardUser', JSON.stringify({
                    userId: userId,
                    email: userData.email,
                    name: userData.name,
                    role: userData.role
                }));
                
                // Update last login
                await db.ref(`users/${userId}`).update({
                    lastLogin: Date.now()
                });
                
                // Show success message
                successMsg.textContent = '✅ Login successful! Redirecting...';
                successMsg.style.display = 'block';
                
                // Redirect to dashboard
                setTimeout(() => {
                    window.location.href = 'trivox-admin-dashboard-WORKING.html';
                }, 1500);
                
            } catch (error) {
                errorMsg.textContent = '❌ ' + error.message;
                errorMsg.style.display = 'block';
                loginBtn.disabled = false;
                loginBtn.textContent = '🔓 Login to Dashboard';
            }
        });
    </script>
</body>
