            background: rgba(15, 20, 41, 0.4);
            border: 1px solid rgba(46, 97, 254, 0.15);
            border-radius: 16px;
            padding: 2.5rem 3rem;
            margin-bottom: 2rem;
        }

        .cs-built h4 {
            font-size: 1.3rem;
            font-weight: 700;
            color: #fff;
            margin-bottom: 1rem;
        }

        .cs-built p {
            color: var(--text-gray);
            line-height: 1.8;
            margin-bottom: 1.5rem;
        }

        .cs-bullets {
            list-style: none;
            display: flex;
            flex-wrap: wrap;
            gap: 0.75rem;
            padding: 0;
            margin: 0;
